<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Me | Portfolio</title>
    <style>
        :root {
            --primary-color: #2563eb;
            --bg-color: #f8fafc;
            --card-bg: #ffffff;
            --text-color: #1e293b;
        }

        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 2rem;
            display: flex;
            justify-content: center;
        }

        .portfolio-card {
            background: var(--card-bg);
            padding: 2.5rem;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            max-width: 450px;
            width: 100%;
            text-align: center;
        }

        /* Profile Image Container */
        .profile-container {
            position: relative;
            width: 150px;
            height: 150px;
            margin: 0 auto 1.5rem;
        }

        .profile-pic {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid var(--primary-color);
            background-color: #e2e8f0;
        }

        /* Hidden File Input */
        .file-input {
            display: none;
        }

        /* Custom Upload Button Style */
        .upload-btn {
            margin-top: 10px;
            display: inline-block;
            padding: 0.5rem 1rem;
            font-size: 0.875rem;
            font-weight: 600;
            color: white;
            background-color: var(--primary-color);
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s ease;
        }

        .upload-btn:hover {
            background-color: #1d4ed8;
        }

        h1 {
            margin: 0.5rem 0;
            font-size: 1.75rem;
        }

        p {
            color: #64748b;
            line-height: 1.6;
        }
    </style>
</head>
<body>

    <div class="portfolio-card">
        <div class="profile-container">
            <img src="https://via.placeholder.com/150" alt="Profile Picture" id="profile-img" class="profile-pic">
        </div>
        
        <label for="image-picker" class="upload-btn">Change Photo</label>
        <input type="file" id="image-picker" class="file-input" accept="image/*">

        <h1>Your Name</h1>
        <p>Welcome to my portfolio! I am passionate about technology, creative problem-solving, and continuous learning. Feel free to modify this section to showcase your professional background, skills, and projects.</p>
    </div>

    <script>
        const imagePicker = document.getElementById('image-picker');
        const profileImg = document.getElementById('profile-img');

        // 1. Check if an image was previously saved in localStorage on page load
        window.addEventListener('DOMContentLoaded', () => {
            const savedImage = localStorage.getItem('portfolio-profile-pic');
            if (savedImage) {
                profileImg.src = savedImage;
            }
        });

        // 2. Handle the file upload and conversion to Base64 string
        imagePicker.addEventListener('change', function() {
            const file = this.files[0];
            
            if (file) {
                const reader = new FileReader();
                
                reader.addEventListener('load', function() {
                    // Update the image source on the page
                    profileImg.src = reader.result;
                    // Save the image string to localStorage
                    localStorage.setItem('portfolio-profile-pic', reader.result);
                });
                
                // Read the image file as a data URL
                reader.readAsDataURL(file);
            }
        });
    </script>
</body>
</html>
